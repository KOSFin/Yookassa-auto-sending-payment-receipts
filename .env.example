# =========================================================
# YooKassa Auto Relay - Environment Example
# =========================================================
# Как использовать:
# 1) Скопируйте файл: cp .env.example .env (Linux/macOS) или Copy-Item .env.example .env (PowerShell)
# 2) Замените значения под ваш сервер
# 3) Для production обязательно задайте PANEL_LOGIN/PANEL_PASSWORD
#
# Формат boolean: true | false
# Формат integer: целое число (без кавычек)
#
# =========================================================
# PostgreSQL (ОБЯЗАТЕЛЬНО)
# =========================================================
# Имя БД.
POSTGRES_DB=yookassa_auto
# Пользователь БД.
POSTGRES_USER=postgres
# Пароль БД. В production используйте сложный пароль.
POSTGRES_PASSWORD=change-me-strong-password

# =========================================================
# App Runtime
# =========================================================
# Режим: production | development
APP_ENV=production
# Включать ли debug-режим FastAPI.
APP_DEBUG=false

# Интервал опроса worker (секунды). Рекомендуемо: 10-30.
WORKER_POLL_INTERVAL_SECONDS=15
# Запускать worker внутри backend-контейнера.
# Обычно false (используется отдельный сервис worker).
RUN_EMBEDDED_WORKER=false

# --- Retry настройки для задач ---
# Базовый интервал повтора при временных ошибках (например, 503 у MyTax).
# При первой ошибке = TASK_RETRY_BASE_SECONDS,
# при второй = TASK_RETRY_BASE_SECONDS * TASK_RETRY_EXPONENTIAL_MULTIPLIER,
# при третьей = TASK_RETRY_BASE_SECONDS * (TASK_RETRY_EXPONENTIAL_MULTIPLIER^2), и т.д.
TASK_RETRY_BASE_SECONDS=60
# Максимальный интервал retry (секунды). При достижении больше не растёт.
TASK_RETRY_MAX_SECONDS=1800
# Множитель экспоненциального роста. 2 = удвоение каждый раз.
TASK_RETRY_EXPONENTIAL_MULTIPLIER=2
# Раз в сколько попыток слать уведомление в Telegram при повторах.
# 5 = отправляется при попытках 0, 5, 10, 15...
TELEGRAM_RETRY_NOTIFICATION_INTERVAL=5

# Публичный базовый URL прокси, нужен для формирования внешних ссылок.
# Пример: https://billing.example.com
PROXY_BASE_URL=https://example.com

# HTTP порт прокси на хосте. По умолчанию в compose 90.
# Для стандартного HTTP можно поставить 80.
PROXY_HTTP_PORT=90

# =========================================================
# Panel Authentication (ОБЯЗАТЕЛЬНО для работы панели)
# =========================================================
# Если PANEL_LOGIN или PANEL_PASSWORD пустые,
# UI-панель будет заблокирована.
PANEL_LOGIN=admin
PANEL_PASSWORD=change-me-now

# Имя cookie сессии панели.
PANEL_AUTH_COOKIE_NAME=yk_panel_session
# TTL сессии (секунды). 86400 = 24 часа.
PANEL_AUTH_TOKEN_TTL_SECONDS=86400
# Секрет подписи токена. Настоятельно рекомендуется задать вручную.
PANEL_AUTH_SECRET=replace-with-long-random-secret
# Secure cookie: true для HTTPS, false для локального HTTP.
PANEL_AUTH_COOKIE_SECURE=true

# =========================================================
# Webhook Anti-Fraud (единый флаг)
# =========================================================
# Единый переключатель антифрода:
# - проверка IP диапазонов YooKassa
# - проверка статуса объекта через YooKassa API
WEBHOOK_ANTIFRAUD_ENABLED=false

# Данные API YooKassa (нужны, если WEBHOOK_ANTIFRAUD_ENABLED=true)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Legacy-переменная (оставлена для обратной совместимости).
# Используйте WEBHOOK_ANTIFRAUD_ENABLED вместо неё.
WEBHOOK_IP_VALIDATION=false
